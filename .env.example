# ============================================================
# Sweets Website — Environment Configuration Example
# ============================================================
# Copy this file to .env and fill in the real values.
# ============================================================

# Application Mode
# Use "production" on live server, "development" locally
APP_ENV=development
APP_DEBUG=true

# ──────────────────────────────────────────────────────────
# Database Credentials
# For local Docker setup:
#   DB_HOST=db
#   DB_NAME=sweets_db
#   DB_USER=root
#   DB_PASS=secret_pass
# For local XAMPP setup:
#   DB_HOST=127.0.0.1
#   DB_NAME=sweets_db
#   DB_USER=root
#   DB_PASS=
# ──────────────────────────────────────────────────────────
DB_HOST=db
DB_NAME=sweets_db
DB_USER=root
DB_PASS=secret_pass

# ──────────────────────────────────────────────────────────
# Cloudflare Turnstile (Bot Protection on Login/Checkout)
# ──────────────────────────────────────────────────────────
TURNSTILE_SITE_KEY=your_live_site_key
TURNSTILE_SECRET_KEY=your_live_secret_key

# Queue / Cache
QUEUE_CONNECTION=sync

# Redis (Optional)
REDIS_URL=

# ──────────────────────────────────────────────────────────
# Payment Gateway (Razorpay)
# ──────────────────────────────────────────────────────────
RAZORPAY_KEY=rzp_test_Sny0ygAGL5xa2q
RAZORPAY_SECRET=Q9KGZATrGgBa9WBZQbbwaXSK

# UPI Settings
UPI_ID=vijayakaradant@upi
UPI_MERCHANT="Vijaya Karadant Sweets"

# ──────────────────────────────────────────────────────────
# SMTP Email Settings (Gmail App Password)
# ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=esakiraj006@gmail.com
SMTP_PASSWORD=koopwlaeofxigsmh
SMTP_FROM_EMAIL=esakiraj006@gmail.com
SMTP_FROM_NAME="Vijaya Karadant"
SMTP_SECURE=tls

# Shipping Rate Settings (in INR)
SHIPPING_STANDARD=50.00
SHIPPING_EXPRESS=150.00
SHIPPING_FREE_THRESHOLD=1000.00

# ──────────────────────────────────────────────────────────
# Session Security
# ──────────────────────────────────────────────────────────
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict
